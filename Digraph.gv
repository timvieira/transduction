digraph {
	graph [rankdir=LR]
	node [fontname=Monospace fontsize=8 height=.05 margin="0.055,0.042" shape=box style=rounded width=.05]
	edge [arrowsize=0.3 fontname=Monospace fontsize=8]
	<start_0> [label="" height=0 shape=point width=0]
	<start_0> -> 0 [label=""]
	0 [label=0 peripheries=2]
	1 [label=1 peripheries=1]
	2 [label=2 peripheries=2]
	3 [label=3 peripheries=2]
	0 -> 1 [label="a:ε"]
	0 -> 2 [label="a:c"]
	1 -> 3 [label="b:c"]
	2 -> 3 [label="a:c"]
	3 -> 3 [label="a:c
b:c"]
}
